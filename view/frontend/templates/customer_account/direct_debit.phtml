<?php
declare(strict_types=1);

use Magento\Framework\View\Element\Template;
use Magento\Vault\Api\Data\PaymentTokenInterface;
use Unzer\PAPI\Block\Customer\DirectDebitRenderer;

/** @var Template|DirectDebitRenderer $block */

$maskedIban = $block->escapeHtml($block->getMaskedIban());
$holder = $block->escapeHtml($block->getAccountHolder());
?>
<tr class="vault-sepa-row">
    <td class="col card-number" data-th="<?= $block->escapeHtml(__('Account')) ?>">
        <?= $maskedIban ?>
    </td>

    <td class="col card-expire" data-th="<?= $block->escapeHtml(__('Expiration Date')) ?>">
        <?= $holder ?>
    </td>

    <td class="col card-type" data-th="<?= $block->escapeHtml(__('Type')) ?>">
        <?= $block->escapeHtml(__('SEPA Direct Debit')) ?>
    </td>

    <td class="col actions" data-th="<?= $block->escapeHtml(__('Actions')) ?>">
        <form class="form"
              action="<?= $block->escapeUrl($block->getUrl('vault/cards/deleteaction')) ?>"
              method="post">
            <?= $block->getBlockHtml('formkey') ?>

            <input type="hidden"
                   name="<?= PaymentTokenInterface::PUBLIC_HASH ?>"
                   value="<?= $block->getToken()->getPublicHash() ?>"/>

            <button type="submit"
                    class="action delete"
                    data-mage-init='{
                        "Magento_Vault/js/customer_account/deleteWidget": {
                            "type": "popup",
                            "modalClass": "my-credit-cards-popup",
                            "toggleEvent": "click",
                            "title": "<?= $block->escapeHtmlAttr(__('Delete')) ?>",
                            "content": "<?= $block->escapeHtmlAttr(
                        __('Are you sure you want to delete this SEPA mandate: %1 (%2)?', $maskedIban, $holder)
                    ) ?>"
                        }
                    }'>
                <span><?= $block->escapeHtml(__('Delete')) ?></span>
            </button>
        </form>
    </td>
</tr>
